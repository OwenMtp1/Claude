{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BD Report",
  "version": "1.16.0",
  "identifier": "app.bdreport.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BD Report",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Pilotez votre prospection. Encaissez vos primes.",
    "longDescription": "BD Report — l'espace sales tout-en-un des BDR / SDR : rendez-vous, pipeline, primes & commissions, dashboards, pilotage d'équipe et support client."
  }
}
